# PRIMA — Environment Template
# Salin file ini menjadi `.env.local` lalu isi nilai sebenarnya.
# JANGAN commit `.env.local` ke git (sudah ada di .gitignore).
#
# Branch aktif: mysql (Postgres/Neon DATABASE_URL tidak dipakai lagi)

# ─── MySQL (WAJIB) ────────────────────────────────────────────────
MYSQL_HOST="localhost"
MYSQL_PORT="3306"
MYSQL_USER="prima_user"
MYSQL_PASSWORD="<set-strong-password>"
MYSQL_DATABASE="prima_db"
MYSQL_SSL="false"

# ─── JWT / Session (WAJIB) ────────────────────────────────────────
# Generate: `node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"`
# Minimal 32 chars — kalau pendek/kosong, app throw fatal saat startup (SEC-C1).
JWT_SECRET="<generate-min-32-chars>"

# ─── Rate-limit backend (pilih SALAH SATU; auto-detect di ratelimit.ts) ───
# Prioritas: Upstash (kalau URL terisi) → Redis lokal (REDIS_URL) → fail-open (off).
# Dev/laptop: pakai Upstash. Server kantor: kosongkan Upstash, isi REDIS_URL.
UPSTASH_REDIS_REST_URL="https://<your-instance>.upstash.io"
UPSTASH_REDIS_REST_TOKEN="<your-token>"
# Redis lokal di server (tanpa kuota). Aktif hanya jika Upstash di atas kosong.
# REDIS_URL="redis://127.0.0.1:6379"

# ─── Gmail SMTP (WAJIB untuk reset password & notif email) ────────
# App Password (16 char), bukan password Google asli. https://myaccount.google.com/apppasswords
GMAIL_USER="<youraccount@gmail.com>"
GMAIL_APP_PASSWORD="<16-char-app-password>"
# Sama dengan GMAIL_USER di atas — diekspos ke client cuma untuk display
# "From Email" di Admin Panel → Email Quota. Kosongkan → fallback ke
# 'admin@example.com'. Tidak dipakai untuk kirim email (yang itu pakai GMAIL_USER).
NEXT_PUBLIC_GMAIL_USER="<youraccount@gmail.com>"

# ─── Google Drive (OPSIONAL — untuk upload file usulan) ───────────
GOOGLE_DRIVE_FOLDER_ID="<folder-id>"
GOOGLE_OAUTH_CLIENT_ID="<xxx.apps.googleusercontent.com>"
GOOGLE_OAUTH_CLIENT_SECRET="<client-secret>"
GOOGLE_OAUTH_REFRESH_TOKEN="<refresh-token>"
# Folder arsip docx LKJIP (OPSIONAL — id setelah /folders/ di URL Drive).
# Kosongkan untuk menonaktifkan arsip Drive. Folder harus milik/di-share ke akun OAuth di atas.
GOOGLE_DRIVE_FOLDER_ID_LKJIP="<folder-id-lkjip>"

# ─── Cloudflare Turnstile (WAJIB di production untuk login CAPTCHA) ──
# Test keys (always-pass) di bawah ini hanya untuk dev/CI:
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"

# ─── Cron Jobs (WAJIB untuk endpoint /api/cron/*) ─────────────────
# Generate: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
# Minimal 32 chars. Dipakai header `Authorization: Bearer ${CRON_SECRET}`.
# Dipakai oleh: purge-retention, promotion-complete, promotion-expire.
CRON_SECRET="<generate-min-32-chars>"

# ─── Role Promotion Ladder (WAJIB untuk modul Promotion) ──────────
# Konsep: docs/session/ROLE_PROMOTION_CONCEPT.md
#
# PROMOTION_SECRET — user input ini saat klik "Upgrade Role" (L2).
# Format memorable 12-16 char (min 8, max 64), dishare offline dari owner
# ke user yang berhak upgrade. Contoh: "Prima-XXXX-2026" (rotasi tahunan).
# Brute force di-block oleh L4 rate-limit (3 attempt/24 jam → lock).
PROMOTION_SECRET="Prima-XXXX-2026"
#
# RECOVERY_SECRET — khusus all-SA-locked emergency scenario (single-use).
# Tidak pernah user input lewat UI; cuma dipakai owner via SQL/admin tool.
# Generate: `openssl rand -hex 16` (32 char hex maksimum entropy).
PROMOTION_RECOVERY_SECRET="<generate-32-char-hex>"
#
# Comma-separated email owner (max 3). Penerima alert bootstrap & emergency.
PROMOTION_OWNER_EMAILS="owner@example.com"

# ─── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
